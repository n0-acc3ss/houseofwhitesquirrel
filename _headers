/*
  # Prevent clickjacking
  X-Frame-Options: SAMEORIGIN

  # Block MIME-type sniffing
  X-Content-Type-Options: nosniff

  # Enable XSS filter in older browsers
  X-XSS-Protection: 1; mode=block

  # Referrer policy
  Referrer-Policy: strict-origin-when-cross-origin

  # Permissions policy — disable unused browser features
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()

  # Content Security Policy
  # - Allows Google Fonts (stylesheet + fonts)
  # - Logo is base64-embedded so no external image host needed
  # - Allows inline styles and scripts (required for single-file app)
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none';

  # Cache static assets for 1 hour
  Cache-Control: public, max-age=3600, must-revalidate

/*.html
  # HTML — revalidate immediately so menu updates go live right away
  Cache-Control: public, max-age=0, must-revalidate
